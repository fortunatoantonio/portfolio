# Copia questo file in .env e inserisci i tuoi valori reali.
# Il file .env NON viene mai committato su GitHub (è in .gitignore).
#
# Dove trovi questi valori su EmailJS:
#   Service ID  → emailjs.com > Email Services > il tuo servizio
#   Template ID → emailjs.com > Email Templates > il tuo template
#   Public Key  → emailjs.com > Account > API Keys

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
